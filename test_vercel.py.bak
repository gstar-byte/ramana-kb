import requests
import json

TOKEN = 'vcp_6qQrEND04FntvMjAs6HDoHo2Kdv8he2utq43KsSlz2yFZF1ZoH0PkCmB'
resp = requests.get('https://api.vercel.com/v6/deployments', headers={'Authorization': f'Bearer {TOKEN}'}, params={'project': 'ramana-kb', 'limit': 3})
print(f'Status: {resp.status_code}')
data = resp.json()
for d in data.get('deployments', [])[:2]:
    print(json.dumps(d, indent=2, ensure_ascii=False)[:600])
    print('---')
