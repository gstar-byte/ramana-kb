---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<BaseLayout title="拉玛那·马哈希知识库 - 传承自阿鲁那佳拉圣山" currentPage="首页">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>🙏 拉玛那·马哈希知识库</h1>
      <p class="subtitle">Ramana Maharshi Interactive Knowledge Base</p>
      <p style="color:var(--text-muted);margin-top:0.75rem;font-size:0.95rem;">传承自印度阿鲁那佳拉圣山 · 自我了悟之道</p>
    </header>

    <!-- 可点击的统计卡片 -->
    <div class="stats-grid">
      <a href="/books" class="stat-card">
        <div class="number">18</div>
        <div class="label">核心著作</div>
        <span class="arrow">→ 查看全部</span>
      </a>
      <a href="/concepts" class="stat-card">
        <div class="number">30+</div>
        <div class="label">核心概念</div>
        <span class="arrow">→ 探索概念</span>
      </a>
      <a href="/methods" class="stat-card">
        <div class="number">100+</div>
        <div class="label">精选问答</div>
        <span class="arrow">→ 研读问答</span>
      </a>
      <a href="/persons" class="stat-card">
        <div class="number">3</div>
        <div class="label">关键人物</div>
        <span class="arrow">→ 阅读传记</span>
      </a>
    </div>

    <!-- 快速入口 -->
    <div class="card" style="margin-top:2rem;">
      <h2 style="color:var(--primary);margin-bottom:1rem;font-size:1.1rem;">📍 快速入口</h2>
      <div class="quick-entry">
        <a href="/books">
          <div class="icon">📚</div>
          <div>书籍总览</div>
        </a>
        <a href="/concepts">
          <div class="icon">🔮</div>
          <div>核心概念</div>
        </a>
        <a href="/methods">
          <div class="icon">🛤️</div>
          <div>修行方法</div>
        </a>
        <a href="/persons">
          <div class="icon">👤</div>
          <div>人物索引</div>
        </a>
        <a href="/graph">
          <div class="icon">🕸️</div>
          <div>知识图谱</div>
        </a>
        <a href="/persons/ramana">
          <div class="icon">🙏</div>
          <div>马哈希传记</div>
        </a>
      </div>
    </div>

    <!-- 热门书籍 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;font-size:1.1rem;">💎 热门书籍</h2>
      <div style="display:grid;gap:1rem;">
        <a href="/books/be-as-you-are/" class="book-card">
          <h3>📖 走向静默，如你本来</h3>
          <div class="meta">Be As You Are | 大卫·高德曼 编</div>
          <p class="desc">马哈希最核心的问答精选，进入马哈希教法的最佳入门读物</p>
        </a>
        <a href="/books/gems/" class="book-card">
          <h3>💎 宝钻集</h3>
          <div class="meta">Gems from Bhagavan</div>
          <p class="desc">马哈希语录精华，每一则都如宝石般珍贵</p>
        </a>
        <a href="/books/talks/" class="book-card">
          <h3>💬 对谈录</h3>
          <div class="meta">Talks with Sri Ramana Maharshi</div>
          <p class="desc">与马哈希的对话记录，涵盖修行生活的方方面面</p>
        </a>
        <a href="/books/day-by-day/" class="book-card">
          <h3>📅 日日与彼</h3>
          <div class="meta">Day by Day with Bhagavan</div>
          <p class="desc">弟子记录的马哈希日常教示</p>
        </a>
      </div>
    </div>

    <!-- 核心概念标签云 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;font-size:1.1rem;">🔮 核心概念</h2>
      <div class="concept-tags">
        <a href="/concepts/atman" class="tag">真我/Atman</a>
        <a href="/concepts/brahman" class="tag">梵/Brahman</a>
        <a href="/concepts/mind" class="tag">心智/Citta</a>
        <a href="/concepts/ego" class="tag">自我/Ego</a>
        <a href="/concepts/whoami" class="tag">"我是谁？"</a>
        <a href="/concepts/moksha" class="tag">解脱/Moksha</a>
        <a href="/concepts/grace" class="tag">恩典/Grace</a>
        <a href="/concepts/maya" class="tag">摩耶/Maya</a>
        <a href="/concepts/karma" class="tag">业力/Karma</a>
        <a href="/concepts/samadhi" class="tag">三摩地/Samadhi</a>
        <a href="/concepts/silence" class="tag">静默/Silence</a>
        <a href="/concepts/surrender" class="tag">臣服/Surrender</a>
        <a href="/concepts/guru" class="tag">上师/Guru</a>
        <a href="/concepts/jnana" class="tag">般若/Jnana</a>
        <a href="/concepts/dhyana" class="tag">禅定/Dhyana</a>
      </div>
    </div>

    <!-- 每日一读 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;font-size:1.1rem;">📜 每日一读</h2>

      <div class="quote-box">
        "知道你自己，一切都会被知晓。"
        <div class="source">— 室利·拉玛那·马哈希</div>
      </div>

      <div class="quote-box">
        "心智是碎片，真我是整体。一旦碎片融入整体，它们就不存在了。只有整体存在。"
        <div class="source">—《宝钻集》</div>
      </div>

      <div class="quote-box">
        "证悟不是到达某个地方。它是认识到你一直在那里，只是没有意识到。"
        <div class="source">— 室利·拉玛那·马哈希</div>
      </div>
    </div>

    <!-- 关于马哈希 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;font-size:1.1rem;">👤 关于马哈希</h2>
      <p style="margin-bottom:1rem;">室利·拉玛那·马哈希（Sri Ramana Maharshi, 1879-1950）是印度近代最伟大的灵性导师之一。16岁时经历神秘体验，悟见真我。此后五十年在阿鲁那佳拉圣山静修，以静默和简直接的方式教导"我是谁"的参究法。</p>
      <a href="/persons/ramana" class="tag">阅读完整传记 →</a>
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
      <p style="margin-top:0.5rem;font-size:0.85rem;">本知识库整合了18本核心著作，涵盖问答、语录、日记、传记等多种形式</p>
    </footer>
  </main>
</BaseLayout>
