---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const concepts = [
  { id: 'atman', title: '真我/Atman', category: '本体论', desc: '最核心的概念，指永恒不变的真实自我。', icon: '🔮' },
  { id: 'brahman', title: '梵/Brahman', category: '本体论', desc: '宇宙终极实在，与真我无二无别。', icon: '🌟' },
  { id: 'mind', title: '心智/Citta', category: '心智与自我', desc: '心的运作，包括念头、情绪、记忆等。', icon: '🧠' },
  { id: 'ego', title: '自我/Ego', category: '心智与自我', desc: '虚幻的个体身份认同，是修行的主要障碍。', icon: '🧠' },
  { id: 'whoami', title: '"我是谁？"', category: '修行法门', desc: '马哈希最核心的参究法门。', icon: '🔍' },
  { id: 'moksha', title: '解脱/Moksha', category: '解脱与境界', desc: '从生死轮回中彻底解脱。', icon: '🕊️' },
  { id: 'grace', title: '恩典/Grace', category: '上师与恩典', desc: '上师的慈悲加持。', icon: '✨' },
  { id: 'samadhi', title: '三摩地/Samadhi', category: '修行法门', desc: '深度冥想状态。', icon: '🧘' },
  { id: 'silence', title: '静默/Silence', category: '上师与恩典', desc: '马哈希最主要的教示方式。', icon: '🤫' },
  { id: 'karma', title: '业力/Karma', category: '业力与轮回', desc: '行为及其果报。', icon: '☸️' },
  { id: 'surrender', title: '臣服/Surrender', category: '修行法门', desc: '向真我臣服的修行方法。', icon: '🙏' },
  { id: 'guru', title: '上师/Guru', category: '上师与恩典', desc: '灵性导师的重要性。', icon: '👆' },
];
---

<BaseLayout title="核心概念 - 拉玛那·马哈希知识库" currentPage="概念">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>🔮 核心概念</h1>
      <p class="subtitle">30+ 核心概念 · 深度解读</p>
    </header>

    <!-- 分类标签 -->
    <div class="tab-nav" id="tabNav">
      <button class="tab-btn active" data-category="全部">全部</button>
      <button class="tab-btn" data-category="本体论">本体论</button>
      <button class="tab-btn" data-category="心智与自我">心智与自我</button>
      <button class="tab-btn" data-category="修行法门">修行法门</button>
      <button class="tab-btn" data-category="上师与恩典">上师与恩典</button>
    </div>

    <!-- 概念网格 -->
    <div class="concept-categories" id="conceptsGrid">
      {concepts.map(concept => (
        <a href={`/concepts/${concept.id}/`} class="concept-category" data-category={concept.category} style="text-decoration:none;">
          <h3>{concept.icon} {concept.title}</h3>
          <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.5rem;">{concept.category}</p>
          <p style="font-size:0.9rem;">{concept.desc}</p>
        </a>
      ))}
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
    </footer>
  </main>
</BaseLayout>

<script>
  // 分类筛选功能
  const tabNav = document.getElementById('tabNav');
  const conceptsGrid = document.getElementById('conceptsGrid');
  const cards = conceptsGrid?.querySelectorAll('.concept-category');
  const buttons = tabNav?.querySelectorAll('.tab-btn');

  buttons?.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      
      // 更新按钮状态
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // 筛选概念
      cards?.forEach(card => {
        const cardCat = card.getAttribute('data-category');
        if (category === '全部' || cardCat === category) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .tab-nav {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .tab-btn {
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.95rem;
    transition: all 0.2s;
  }
  .tab-btn:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
  .tab-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
</style>
