---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const books = [
  { id: 'be-as-you-are', title: '走向静默，如你本来', titleEn: 'Be As You Are', author: '大卫·高德曼 编', desc: '马哈希最核心的问答精选，进入马哈希教法的最佳入门读物', icon: '📖', category: '经典著作' },
  { id: 'gems', title: '宝钻集', titleEn: 'Gems from Bhagavan', author: '马哈希', desc: '马哈希语录精华，每一则都如宝石般珍贵', icon: '💎', category: '经典著作' },
  { id: 'talks', title: '对谈录', titleEn: 'Talks with Sri Ramana Maharshi', author: '记录', desc: '与马哈希的对话记录，涵盖修行生活的方方面面', icon: '💬', category: '对话与日记' },
  { id: 'back-to-heart', title: '回到你心中', titleEn: 'Back to the Heart', author: '大卫·高德曼', desc: '收录马哈希弟子们的深刻问答与修行体验', icon: '📕', category: '对话与日记' },
  { id: 'day-by-day', title: '日日与彼', titleEn: 'Day by Day with Bhagavan', author: '记录', desc: '弟子记录的马哈希日常教示', icon: '📅', category: '对话与日记' },
  { id: 'face-to-face', title: '面对面', titleEn: 'Face to Face', author: '记录', desc: '与马哈希的私密对话记录', icon: '👁️', category: '对话与日记' },
  { id: 'maharshi-gospel', title: '马哈希福音', titleEn: "Maharshi's Gospel", author: '马哈希', desc: '马哈希亲述的灵性教言', icon: '📜', category: '对话与日记' },
  { id: 'maha-yoga', title: '大瑜伽', titleEn: 'Maha Yoga', author: '约瑟夫·韦尔东', desc: '关于臣服与上师恩典的经典著作', icon: '🧘', category: '哲学专著' },
  { id: 'search-secret-india', title: '秘密印度', titleEn: 'A Search in Secret India', author: '保罗·布隆顿', desc: '发现马哈希的西方朝圣者记录', icon: '🔍', category: '朝圣记录' },
  { id: 'collected-works', title: '全集', titleEn: 'Collected Works', author: '马哈希', desc: '马哈希著作全集', icon: '📚', category: '经典著作' },
];
---

<BaseLayout title="书籍总览 - 拉玛那·马哈希知识库" currentPage="书籍">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>📚 书籍总览</h1>
      <p class="subtitle">18本核心著作 · 持续更新中</p>
    </header>

    <!-- 分类标签 -->
    <div class="tab-nav" id="tabNav">
      <button class="tab-btn active" data-category="全部">全部</button>
      <button class="tab-btn" data-category="经典著作">经典著作</button>
      <button class="tab-btn" data-category="对话与日记">对话与日记</button>
      <button class="tab-btn" data-category="哲学专著">哲学专著</button>
      <button class="tab-btn" data-category="朝圣记录">朝圣记录</button>
    </div>

    <!-- 书籍网格 -->
    <div class="concept-categories" id="booksGrid">
      {books.map(book => (
        <a href={`/books/${book.id}/`} class="book-card" data-category={book.category} style="text-decoration:none;">
          <h3 style="color:var(--primary);">{book.icon} {book.title}</h3>
          <div class="meta">{book.titleEn}</div>
          <p class="desc">{book.desc}</p>
          <span class="tag" style="margin-top:0.5rem;display:inline-block;">{book.category}</span>
        </a>
      ))}
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
    </footer>
  </main>
</BaseLayout>

<script>
  // 分类筛选功能
  const tabNav = document.getElementById('tabNav');
  const booksGrid = document.getElementById('booksGrid');
  const cards = booksGrid?.querySelectorAll('.book-card');
  const buttons = tabNav?.querySelectorAll('.tab-btn');

  buttons?.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      
      // 更新按钮状态
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // 筛选书籍
      cards?.forEach(card => {
        const cardCat = card.getAttribute('data-category');
        if (category === '全部' || cardCat === category) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .tab-nav {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .tab-btn {
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.95rem;
    transition: all 0.2s;
  }
  .tab-btn:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
  .tab-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
</style>
