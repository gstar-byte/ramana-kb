---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const chapters = [
  { id: 1, title: '第一章：真我的本质', summary: '马哈希亲述真我的本质与真相。' },
  { id: 2, title: '第二章：心智的运作', summary: '心智的本质与运作机制。' },
  { id: 3, title: '第三章：修行方法', summary: '"我是谁？"参究法的具体实践。' },
  { id: 4, title: '第四章：静默的力量', summary: '静默作为教示方式的重要性。' },
  { id: 5, title: '第五章：解脱与证悟', summary: '解脱的状态与证悟的过程。' },
];
---

<BaseLayout title="马哈希福音 - 拉玛那·马哈希知识库" currentPage="书籍">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>📜 马哈希福音</h1>
      <p class="subtitle">Maharshi's Gospel | 马哈希</p>
      <p style="color:var(--text-muted);margin-top:0.75rem;font-size:0.95rem;">马哈希亲述的灵性教言</p>
    </header>

    <!-- 面包屑 -->
    <div class="breadcrumb" style="padding:1rem 0;color:var(--text-muted);">
      <a href="/">首页</a> /
      <a href="/books">书籍</a> /
      <span style="color:var(--text);">马哈希福音</span>
    </div>

    <!-- 章节列表 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1.5rem;">📖 章节内容</h2>
      {chapters.map(chapter => (
        <div class="chapter-card">
          <h4>{chapter.title}</h4>
          <p class="summary">{chapter.summary}</p>
        </div>
      ))}
    </div>

    <!-- 相关概念 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;">🔗 相关概念</h2>
      <div class="concept-tags">
        <a href="/concepts/atman" class="tag">真我</a>
        <a href="/concepts/whoami" class="tag">"我是谁？"</a>
        <a href="/concepts/silence" class="tag">静默</a>
        <a href="/concepts/moksha" class="tag">解脱</a>
      </div>
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
    </footer>
  </main>
</BaseLayout>

<script>
  // 章节点击展开
  document.querySelectorAll('.chapter-card').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('expanded');
    });
  });
</script>

<style>
  .chapter-card.expanded .summary {
    display: none;
  }
  .chapter-card.expanded .chapter-content {
    display: block;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .chapter-card .chapter-content {
    display: none;
  }
</style>