---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const chapters = [
  { id: 1, title: '第一章：大瑜伽的本质', summary: '探讨大瑜伽的核心概念与本质。' },
  { id: 2, title: '第二章：臣服的力量', summary: '臣服在修行中的重要性与实践方法。' },
  { id: 3, title: '第三章：上师恩典', summary: '上师恩典在灵性成长中的作用。' },
  { id: 4, title: '第四章：实践指导', summary: '大瑜伽的具体实践方法与要点。' },
  { id: 5, title: '第五章：证悟之路', summary: '通过臣服与恩典走向证悟的道路。' },
];
---

<BaseLayout title="大瑜伽 - 拉玛那·马哈希知识库" currentPage="书籍">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>🧘 大瑜伽</h1>
      <p class="subtitle">Maha Yoga | 约瑟夫·韦尔东</p>
      <p style="color:var(--text-muted);margin-top:0.75rem;font-size:0.95rem;">关于臣服与上师恩典的经典著作</p>
    </header>

    <!-- 面包屑 -->
    <div class="breadcrumb" style="padding:1rem 0;color:var(--text-muted);">
      <a href="/">首页</a> /
      <a href="/books">书籍</a> /
      <span style="color:var(--text);">大瑜伽</span>
    </div>

    <!-- 章节列表 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1.5rem;">📖 章节内容</h2>
      {chapters.map(chapter => (
        <div class="chapter-card">
          <h4>{chapter.title}</h4>
          <p class="summary">{chapter.summary}</p>
        </div>
      ))}
    </div>

    <!-- 相关概念 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;">🔗 相关概念</h2>
      <div class="concept-tags">
        <a href="/concepts/surrender" class="tag">臣服</a>
        <a href="/concepts/grace" class="tag">恩典</a>
        <a href="/concepts/guru" class="tag">上师</a>
        <a href="/concepts/moksha" class="tag">解脱</a>
      </div>
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
    </footer>
  </main>
</BaseLayout>

<script>
  // 章节点击展开
  document.querySelectorAll('.chapter-card').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('expanded');
    });
  });
</script>

<style>
  .chapter-card.expanded .summary {
    display: none;
  }
  .chapter-card.expanded .chapter-content {
    display: block;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .chapter-card .chapter-content {
    display: none;
  }
</style>