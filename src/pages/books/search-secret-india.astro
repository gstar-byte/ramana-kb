---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const chapters = [
  { id: 1, title: '第一章：西方人的探索', summary: '保罗·布隆顿寻找灵性导师的旅程。' },
  { id: 2, title: '第二章：遇见马哈希', summary: '布隆顿与马哈希的初次相遇。' },
  { id: 3, title: '第三章：马哈希的教导', summary: '布隆顿记录的马哈希教导。' },
  { id: 4, title: '第四章：修行体验', summary: '布隆顿在圣山的修行体验。' },
  { id: 5, title: '第五章：回归西方', summary: '布隆顿返回西方后的感悟与分享。' },
];
---

<BaseLayout title="秘密印度 - 拉玛那·马哈希知识库" currentPage="书籍">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>🔍 秘密印度</h1>
      <p class="subtitle">A Search in Secret India | 保罗·布隆顿</p>
      <p style="color:var(--text-muted);margin-top:0.75rem;font-size:0.95rem;">发现马哈希的西方朝圣者记录</p>
    </header>

    <!-- 面包屑 -->
    <div class="breadcrumb" style="padding:1rem 0;color:var(--text-muted);">
      <a href="/">首页</a> /
      <a href="/books">书籍</a> /
      <span style="color:var(--text);">秘密印度</span>
    </div>

    <!-- 章节列表 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1.5rem;">📖 章节内容</h2>
      {chapters.map(chapter => (
        <div class="chapter-card">
          <h4>{chapter.title}</h4>
          <p class="summary">{chapter.summary}</p>
        </div>
      ))}
    </div>

    <!-- 相关概念 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;">🔗 相关概念</h2>
      <div class="concept-tags">
        <a href="/concepts/atman" class="tag">真我</a>
        <a href="/concepts/whoami" class="tag">"我是谁？"</a>
        <a href="/concepts/guru" class="tag">上师</a>
        <a href="/concepts/silence" class="tag">静默</a>
      </div>
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
    </footer>
  </main>
</BaseLayout>

<script>
  // 章节点击展开
  document.querySelectorAll('.chapter-card').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('expanded');
    });
  });
</script>

<style>
  .chapter-card.expanded .summary {
    display: none;
  }
  .chapter-card.expanded .chapter-content {
    display: block;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .chapter-card .chapter-content {
    display: none;
  }
</style>