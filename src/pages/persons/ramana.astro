  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>🙏 室利·拉玛那·马哈希</h1>
      <p class="subtitle">Sri Ramana Maharshi | 1879-1950</p>
      <p style="color:var(--text-muted);margin-top:0.75rem;font-size:0.95rem;">印度近代最伟大的灵性导师之一 | 南印度声震寰宇的圣人</p>
    </header>

    <!-- 面包屑 -->
    <div class="breadcrumb" style="padding:1rem 0;color:var(--text-muted);">
      <a href="/">首页</a> /
      <a href="/persons">人物</a> /
