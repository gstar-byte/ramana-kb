"""删除 Vercel 24小时前的部署记录（遍历所有项目）"""
import requests
import json
from datetime import datetime, timezone, timedelta

TOKEN = "vcp_6qQrEND04FntvMjAs6HDoHo2Kdv8he2utq43KsSlz2yFZF1ZoH0PkCmB"
CUTOFF_HOURS = 24

HEADERS = {
    "Authorization": f"Bearer {TOKEN}",
    "Content-Type": "application/json"
}

def delete_deployment(deploy_id):
    resp = requests.delete(
        f"https://api.vercel.com/v13/deployments/{deploy_id}",
        headers=HEADERS
    )
    return resp.status_code in (200, 201, 204)

# 1. 获取所有项目
print("获取所有 Vercel 项目...")
resp = requests.get("https://api.vercel.com/v6/projects", headers=HEADERS, params={"limit": 20})
projects = resp.json().get("projects", [])
project_names = [p["name"] for p in projects]
print(f"项目列表: {project_names}")

now = datetime.now(timezone.utc)
cutoff = now - timedelta(hours=CUTOFF_HOURS)

all_to_delete = []

# 2. 遍历每个项目获取部署
for proj_name in project_names:
    print(f"\n正在查询项目: {proj_name} ...")

    # 分页获取部署（直到没有下一页）
    until_ts = None
    page_count = 0

    while True:
        params = {"project": proj_name, "limit": 100}
        if until_ts:
            params["until"] = until_ts

        resp = requests.get("https://api.vercel.com/v6/deployments", headers=HEADERS, params=params)
        if resp.status_code != 200:
            print(f"  查询失败: {resp.status_code}")
            break

        data = resp.json()
        deployments = data.get("deployments", [])

        if not deployments:
            break

        page_count += 1
        print(f"  第{page_count}页: {len(deployments)} 条部署")

        for d in deployments:
            created_ms = d["created"]
            created_at = datetime.fromtimestamp(created_ms / 1000, tz=timezone.utc)
            age_hours = (now - created_at).total_seconds() / 3600

            if age_hours > CUTOFF_HOURS:
                all_to_delete.append({
                    "id": d["uid"],
                    "url": d.get("url", ""),
                    "name": d.get("name", ""),
                    "created": created_at.strftime("%Y-%m-%d %H:%M"),
                    "age_hours": round(age_hours, 1),
                    "commit_msg": d.get("meta", {}).get("githubCommitMessage", "")[:50]
                })

        # 用最后一条的时间戳继续翻页
        until_ts = deployments[-1]["created"]

        # 如果本页最新部署也不超过24h，可以提前停止
        latest_created = datetime.fromtimestamp(deployments[0]["created"] / 1000, tz=timezone.utc)
        if (now - latest_created).total_seconds() / 3600 <= CUTOFF_HOURS:
            print(f"  已到达 24h 内的记录，停止翻页")
            break

        # 如果只有1条，说明到头了
        if len(deployments) == 1:
            break

print(f"\n{'='*50}")
print(f"当前时间: {now.strftime('%Y-%m-%d %H:%M')} UTC")
print(f"24h 前时间: {cutoff.strftime('%Y-%m-%d %H:%M')} UTC")
print(f"\n{'='*50}")
print(f"共发现 {len(all_to_delete)} 条超过24小时的部署:")

for d in all_to_delete:
    print(f"  [{d['name']}] {d['created']} ({d['age_hours']}h前) {d['url']}")
    if d['commit_msg']:
        print(f"           commit: {d['commit_msg']}")

if not all_to_delete:
    print("没有超过24小时的部署，无需清理")
    exit(0)

total = len(all_to_delete)

# 3. 确认删除
AUTO_CONFIRM = True  # 设为 False 则每次运行前需要手动确认
if AUTO_CONFIRM:
    confirm = "y"
    print(f"\n[自动确认] 开始删除以上 {total} 条部署...")
else:
    confirm = input(f"\n确认删除以上 {total} 条部署？(y/N): ").strip().lower()

if confirm != 'y':
    print("取消删除")
    exit(0)

# 4. 逐一删除
print(f"\n开始删除...")
success = 0
failed = 0
skipped = 0

for d in all_to_delete:
    status = delete_deployment(d["id"])
    if status:
        print(f"  ✅ {d['url']}")
        success += 1
    else:
        print(f"  ❌ 删除失败: {d['url']}（可能已被 Vercel 自动清理）")
        failed += 1

print(f"\n完成: 成功 {success} 条, 失败 {failed} 条")
