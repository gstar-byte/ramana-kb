---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const chapters = [
  { id: 1, title: '第一章：关于自我', summary: '马哈希讲解"我是谁"的参究法，以及如何通过追问自我来证悟真我。' },
  { id: 2, title: '第二章：关于心智', summary: '深入分析心智的本质，区分真实与虚幻。' },
  { id: 3, title: '第三章：关于上师', summary: '讨论上师在修行中的作用，以及如何正确接受上师的教诲。' },
  { id: 4, title: '第四章：关于静默', summary: '马哈希以静默作为主要教示方式的深意。' },
  { id: 5, title: '第五章：关于解脱', summary: '什么是真正的解脱，如何证得解脱。' },
];
---

<BaseLayout title="走向静默，如你本来 - 拉玛那·马哈希知识库" currentPage="书籍">
  <Sidebar slot="sidebar" />

  <main>
    <header class="page-header">
      <h1>📖 走向静默，如你本来</h1>
      <p class="subtitle">Be As You Are | 大卫·高德曼 编</p>
      <p style="color:var(--text-muted);margin-top:0.75rem;font-size:0.95rem;">马哈希最核心的问答精选，进入马哈希教法的最佳入门读物</p>
    </header>

    <!-- 面包屑 -->
    <div class="breadcrumb" style="padding:1rem 0;color:var(--text-muted);">
      <a href="/">首页</a> /
      <a href="/books">书籍</a> /
      <span style="color:var(--text);">走向静默，如你本来</span>
    </div>

    <!-- 章节列表 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1.5rem;">📖 章节内容</h2>
      {chapters.map(chapter => (
        <div class="chapter-card">
          <h4>{chapter.title}</h4>
          <p class="summary">{chapter.summary}</p>
        </div>
      ))}
    </div>

    <!-- 相关概念 -->
    <div class="card">
      <h2 style="color:var(--primary);margin-bottom:1rem;">🔗 相关概念</h2>
      <div class="concept-tags">
        <a href="/concepts/whoami" class="tag">"我是谁？"</a>
        <a href="/concepts/mind" class="tag">心智</a>
        <a href="/concepts/atman" class="tag">真我</a>
        <a href="/concepts/silence" class="tag">静默</a>
      </div>
    </div>

    <footer class="site-footer">
      <p>拉玛那·马哈希知识库 | 传承自印度阿鲁那佳拉圣山</p>
    </footer>
  </main>
</BaseLayout>

<script>
  // 章节点击展开
  document.querySelectorAll('.chapter-card').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('expanded');
    });
  });
</script>

<style>
  .chapter-card.expanded .summary {
    display: none;
  }
  .chapter-card.expanded .chapter-content {
    display: block;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .chapter-card .chapter-content {
    display: none;
  }
</style>
