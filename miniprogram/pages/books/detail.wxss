/* pages/books/detail.wxss */
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: 700; color: var(--gold); }
.subtitle { font-size: 26rpx; color: var(--text2); margin-top: 8rpx; }
.desc { font-size: 28rpx; color: var(--text); margin-top: 16rpx; line-height: 1.6; }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--gold); margin: 32rpx 0 20rpx; }
.chapter-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: var(--card); border-radius: 12rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.chapter-title { font-size: 28rpx; color: var(--text); }
.arrow { color: var(--gold); font-size: 28rpx; }
.empty { text-align: center; padding: 100rpx 0; }
.empty-text { color: var(--text2); font-size: 28rpx; }
