/* pages/index/index.wxss */
.header {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #B8860B; /* Gold */
}

.subtitle {
  font-size: 24rpx;
  color: #6B6560;
  margin-top: 12rpx;
}

.desc {
  font-size: 24rpx;
  color: #6B6560;
  margin-top: 16rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.stat-card {
  width: 48%;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.stat-card .number {
  font-size: 56rpx;
  font-weight: 700;
  color: #B8860B;
}

.stat-card .label {
  font-size: 24rpx;
  color: #6B6560;
  margin-top: 8rpx;
}

.stat-card .arrow {
  font-size: 20rpx;
  color: #B8860B;
  margin-top: 16rpx;
}

.quick-entry {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.entry-item {
  width: 30%;
  text-align: center;
  padding: 24rpx 0;
  background: #F3EDE4;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.entry-item .icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.entry-item text {
  font-size: 24rpx;
  color: #1B1B18;
}

.book-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.book-card {
  padding: 24rpx;
  background: #F3EDE4;
  border-radius: 12rpx;
  border-left: 6rpx solid #B8860B;
}

.book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B1B18;
  margin-bottom: 8rpx;
}

.book-meta {
  font-size: 22rpx;
  color: #6B6560;
  margin-bottom: 12rpx;
}

.book-desc {
  font-size: 26rpx;
  color: #1B1B18;
  line-height: 1.5;
}

.concept-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 24rpx;
  background: rgba(184,134,11,0.12);
  color: #B8860B;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.quote-box {
  padding: 24rpx;
  background: #F3EDE4;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #B8860B;
}

.quote {
  font-size: 28rpx;
  color: #1B1B18;
  font-style: italic;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.source {
  font-size: 22rpx;
  color: #6B6560;
  text-align: right;
}

.about-text {
  font-size: 28rpx;
  color: #1B1B18;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.tag-link {
  color: #B8860B;
  font-size: 26rpx;
  text-align: right;
}
