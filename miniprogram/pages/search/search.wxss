/* pages/search/search.wxss */
.search-box {
  margin-bottom: 24rpx;
}

.search-input {
  background: var(--card);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.result-item {
  background: var(--card);
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.result-type {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: var(--gold-glow);
  color: var(--gold);
  border-radius: 4rpx;
  font-size: 20rpx;
  margin-bottom: 8rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8rpx;
}

.result-excerpt {
  font-size: 24rpx;
  color: var(--text2);
  line-height: 1.5;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: var(--text2);
  font-size: 28rpx;
}
