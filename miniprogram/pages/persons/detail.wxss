/* pages/persons/detail.wxss */
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: 700; color: var(--gold); }
.card { background: var(--card); padding: 32rpx; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.bio-title { font-size: 30rpx; font-weight: 600; color: var(--gold); margin-bottom: 12rpx; }
.bio { font-size: 28rpx; color: var(--text2); line-height: 1.7; margin-bottom: 24rpx; }
.divider { height: 2rpx; background: var(--border); margin: 24rpx 0; }
.content { font-size: 30rpx; color: var(--text); line-height: 1.9; white-space: pre-line; }
