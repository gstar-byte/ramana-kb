/* pages/concepts/index.wxss */
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: 700; color: var(--gold); }
.desc { font-size: 24rpx; color: var(--text2); margin-top: 12rpx; }
.concept-list { display: flex; flex-direction: column; gap: 20rpx; }
.concept-item { background: var(--card); padding: 28rpx; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); border-left: 4rpx solid var(--gold); }
.concept-title { font-size: 32rpx; font-weight: 600; color: var(--text); margin-bottom: 8rpx; }
.concept-desc { font-size: 26rpx; color: var(--text2); }
