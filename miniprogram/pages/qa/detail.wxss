/* pages/qa/detail.wxss */
.card { background: var(--card); padding: 32rpx; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.question { font-size: 34rpx; font-weight: 600; color: var(--text); margin-bottom: 20rpx; }
.divider { height: 2rpx; background: var(--border); margin: 20rpx 0; }
.answer { font-size: 30rpx; color: var(--text); line-height: 1.9; margin-bottom: 24rpx; }
.source { font-size: 24rpx; color: var(--gold); text-align: right; }
