/* pages/qa/index.wxss */
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: 700; color: var(--gold); }
.desc { font-size: 24rpx; color: var(--text2); margin-top: 12rpx; }
.qa-list { display: flex; flex-direction: column; gap: 24rpx; }
.qa-item { background: var(--card); padding: 28rpx; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.question { font-size: 30rpx; font-weight: 600; color: var(--text); margin-bottom: 16rpx; }
.answer-preview { font-size: 26rpx; color: var(--text2); line-height: 1.6; margin-bottom: 12rpx; }
.source { font-size: 22rpx; color: var(--gold); text-align: right; }
